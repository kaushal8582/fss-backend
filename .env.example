MONGODB_URI=mongodb://localhost:27017/fssai
DOWNLOAD_APP_PASSWORD=your-shared-password
JWT_SECRET=change-me
PORT=4001
CLIENT_URL=http://localhost:5174
# Production (no trailing slash):
# CLIENT_URL=https://dataextractvalue.netlify.app

# FSSAI session — copy from server/.env (same values as main server)
BEARER_TOKEN=
COOKIE=
X_AUTH_USER_ID=
FSSAI_USERNAME=
FSSAI_DISPLAY_REF_ID=
FSSAI_PLAIN_PASSWORD=
FSSAI_PASSWORD_ENCRYPTED=
FSSAI_MD5_PASSWORD=
FSSAI_BASE_COOKIE=
AUTH_REFRESH_ON_401=true
# Multiple origins allowed (comma-separated, no trailing slash):
# CLIENT_URL=http://localhost:5174,https://dataextractvalue.netlify.app
